import pandas as pd
import numpy as np
from sklearn.model_selection import train_test_split
from sklearn.feature_extraction import DictVectorizer
from sklearn.tree import DecisionTreeRegressor
from sklearn.ensemble import RandomForestRegressor
from sklearn.metrics import root_mean_squared_error
import warnings
warnings.filterwarnings('ignore')

# Загружаем данные
df = pd.read_csv('jamb_students_performance.csv')  # или ваш путь к файлу

# Подготовка данных
# Преобразуем названия колонок
df.columns = df.columns.str.lower().str.replace(' ', '_')

# Удаляем столбец student_id
df = df.drop('student_id', axis=1)

# Заполняем пропущенные значения нулями
df = df.fillna(0)

# Разделяем на признаки и целевую переменную
X = df.drop('jamb_score', axis=1)
y = df['jamb_score']

# Разделяем на train/validation/test (60%/20%/20%)
X_train_full, X_test, y_train_full, y_test = train_test_split(
    X, y, test_size=0.2, random_state=1
)

X_train, X_val, y_train, y_val = train_test_split(
    X_train_full, y_train_full, test_size=0.25, random_state=1
)  # 0.25 * 0.8 = 0.2 от исходных данных

print(f"Train size: {len(X_train)}")
print(f"Validation size: {len(X_val)}")
print(f"Test size: {len(X_test)}")

# Преобразуем в матрицы с помощью DictVectorizer
dv = DictVectorizer(sparse=True)

# Преобразуем в словари и векторизуем
train_dict = X_train.to_dict(orient='records')
val_dict = X_val.to_dict(orient='records')
test_dict = X_test.to_dict(orient='records')

X_train = dv.fit_transform(train_dict)
X_val = dv.transform(val_dict)
X_test = dv.transform(test_dict)

# Обучаем дерево решений с max_depth=1
dt = DecisionTreeRegressor(max_depth=1, random_state=1)
dt.fit(X_train, y_train)

# Получаем признак для разбиения
feature_names = dv.get_feature_names_out()
split_feature_index = dt.tree_.feature[0]  # индекс признака для первого разбиения
split_feature = feature_names[split_feature_index]

print(f"Признак для разбиения: {split_feature}")

# Обучаем случайный лес
rf = RandomForestRegressor(n_estimators=10, random_state=1, n_jobs=-1)
rf.fit(X_train, y_train)

# Предсказание и расчет RMSE
y_pred = rf.predict(X_val)
rmse = root_mean_squared_error(y_val, y_pred)
print(f"RMSE на валидации: {rmse:.2f}")

# Экспериментируем с n_estimators
scores = []

for n in range(10, 201, 10):
    rf = RandomForestRegressor(n_estimators=n, random_state=1, n_jobs=-1)
    rf.fit(X_train, y_train)
    y_pred = rf.predict(X_val)
    rmse = root_mean_squared_error(y_val, y_pred)
    scores.append((n, rmse))
    print(f"n_estimators={n}, RMSE={rmse:.3f}")

# Находим после какого значения RMSE перестает улучшаться
rmse_values = [score[1] for score in scores]
improvements = [abs(rmse_values[i] - rmse_values[i-1]) for i in range(1, len(rmse_values))]
stable_point = None

for i, imp in enumerate(improvements):
    if imp < 0.001:  # если улучшение меньше 0.001
        stable_point = scores[i][0]
        break

print(f"RMSE стабилизируется после n_estimators={stable_point}")

# Экспериментируем с max_depth и n_estimators
depths = [10, 15, 20, 25]
results = []

for depth in depths:
    depth_scores = []
    for n in range(10, 201, 10):
        rf = RandomForestRegressor(
            n_estimators=n, 
            max_depth=depth, 
            random_state=1, 
            n_jobs=-1
        )
        rf.fit(X_train, y_train)
        y_pred = rf.predict(X_val)
        rmse = root_mean_squared_error(y_val, y_pred)
        depth_scores.append(rmse)
    
    mean_rmse = np.mean(depth_scores)
    results.append((depth, mean_rmse))
    print(f"max_depth={depth}, средний RMSE={mean_rmse:.3f}")

# Находим лучшее значение
best_depth = min(results, key=lambda x: x[1])[0]
print(f"Лучшее значение max_depth: {best_depth}")

# Обучаем модель с заданными параметрами
rf = RandomForestRegressor(
    n_estimators=10, 
    max_depth=20, 
    random_state=1, 
    n_jobs=-1
)
rf.fit(X_train, y_train)

# Получаем важность признаков
feature_names = dv.get_feature_names_out()
feature_importance = rf.feature_importances_

# Создаем DataFrame с важностью признаков
importance_df = pd.DataFrame({
    'feature': feature_names,
    'importance': feature_importance
}).sort_values('importance', ascending=False)

print("Топ-10 важных признаков:")
print(importance_df.head(10))

# Находим самый важный признак из предложенных
candidate_features = [
    'study_hours_per_week',
    'attendance_rate',
    'distance_to_school',
    'teacher_quality'
]

for feature in candidate_features:
    # Ищем признак в списке (возможно с префиксом)
    matching_features = [f for f in feature_names if feature in f]
    if matching_features:
        for match in matching_features:
            importance = feature_importance[list(feature_names).index(match)]
            print(f"{match}: {importance:.4f}")
