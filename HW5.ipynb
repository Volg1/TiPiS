# -*- coding: utf-8 -*-
"""JAMB Exam Score Prediction

Автоматизированный анализ и прогнозирование результатов экзамена JAMB
"""

import pandas as pd
import numpy as np
from sklearn.model_selection import train_test_split
from sklearn.feature_extraction import DictVectorizer
from sklearn.tree import DecisionTreeRegressor
from sklearn.ensemble import RandomForestRegressor
from sklearn.metrics import mean_squared_error
import warnings
warnings.filterwarnings('ignore')


class JAMBScorePredictor:
    """
    Класс для прогнозирования результатов экзамена JAMB
    """
    
    def __init__(self, filepath='jamb_exam_results.csv'):
        """Инициализация с загрузкой данных"""
        self.filepath = filepath
        self.df = None
        self.dv = DictVectorizer(sparse=True)
        self.X_train_encoded = None
        self.X_val_encoded = None
        self.X_test_encoded = None
        self.y_train = None
        self.y_val = None
        self.y_test = None
        self.feature_names = None
        
    def load_and_preprocess(self):
        """Загрузка и предварительная обработка данных"""
        print("="*60)
        print("ЗАГРУЗКА И ПРЕДОБРАБОТКА ДАННЫХ")
        print("="*60)
        
        # Загрузка данных
        self.df = pd.read_csv(self.filepath)
        print(f"Загружено строк: {len(self.df)}")
        
        # Очистка названий колонок
        self.df.columns = self.df.columns.str.lower().str.replace(' ', '_')
        print("✓ Названия колонок приведены к нижнему регистру")
        
        # Удаление ненужных колонок
        if 'student_id' in self.df.columns:
            self.df = self.df.drop('student_id', axis=1)
            print("✓ Удален столбец student_id")
        
        # Заполнение пропусков
        initial_shape = self.df.shape
        self.df = self.df.fillna(0)
        print(f"✓ Пропуски заполнены нулями")
        
        print(f"\nИтоговый размер данных: {self.df.shape}")
        print(f"Колонки: {list(self.df.columns)}")
        
        return self.df
    
    def explore_data(self):
        """Исследовательский анализ данных"""
        print("\n" + "="*60)
        print("ИССЛЕДОВАТЕЛЬСКИЙ АНАЛИЗ ДАННЫХ")
        print("="*60)
        
        print("\nПервые 5 строк:")
        print(self.df.head())
        
        print("\nИнформация о данных:")
        print(self.df.info())
        
        print("\nСтатистика числовых признаков:")
        print(self.df.describe())
        
        print("\nКатегориальные признаки:")
        categorical_cols = self.df.select_dtypes(include=['object']).columns
        for col in categorical_cols:
            print(f"\n{col}:")
            print(self.df[col].value_counts())
    
    def split_data(self, test_size=0.2, val_size=0.25, random_state=1):
        """Разделение данных на train/validation/test"""
        print("\n" + "="*60)
        print("РАЗДЕЛЕНИЕ ДАННЫХ")
        print("="*60)
        
        X = self.df.drop('jamb_score', axis=1)
        y = self.df['jamb_score']
        
        # Первое разделение: train+val / test
        X_train_full, X_test, y_train_full, y_test = train_test_split(
            X, y, test_size=test_size, random_state=random_state
        )
        
        # Второе разделение: train / val
        X_train, X_val, y_train, y_val = train_test_split(
            X_train_full, y_train_full, test_size=val_size, random_state=random_state
        )
        
        self.X_train = X_train
        self.X_val = X_val
        self.X_test = X_test
        self.y_train = y_train
        self.y_val = y_val
        self.y_test = y_test
        
        print(f"Обучающая выборка: {len(X_train)} образцов ({len(X_train)/len(X)*100:.1f}%)")
        print(f"Валидационная выборка: {len(X_val)} образцов ({len(X_val)/len(X)*100:.1f}%)")
        print(f"Тестовая выборка: {len(X_test)} образцов ({len(X_test)/len(X)*100:.1f}%)")
    
    def encode_features(self):
        """Кодирование признаков с помощью DictVectorizer"""
        print("\n" + "="*60)
        print("КОДИРОВАНИЕ ПРИЗНАКОВ")
        print("="*60)
        
        # Преобразование в словари
        train_dict = self.X_train.to_dict(orient='records')
        val_dict = self.X_val.to_dict(orient='records')
        test_dict = self.X_test.to_dict(orient='records')
        
        # Кодирование
        self.X_train_encoded = self.dv.fit_transform(train_dict)
        self.X_val_encoded = self.dv.transform(val_dict)
        self.X_test_encoded = self.dv.transform(test_dict)
        
        self.feature_names = self.dv.get_feature_names_out()
        
        print(f"✓ Признаки закодированы")
        print(f"Количество признаков после кодирования: {len(self.feature_names)}")
    
    def question1_decision_tree_depth1(self):
        """Вопрос 1: Дерево решений с глубиной 1"""
        print("\n" + "="*60)
        print("ВОПРОС 1: ДЕРЕВО РЕШЕНИЙ (max_depth=1)")
        print("="*60)
        
        dt = DecisionTreeRegressor(max_depth=1, random_state=1)
        dt.fit(self.X_train_encoded, self.y_train)
        
        feature_used = self.feature_names[dt.tree_.feature[0]]
        
        print(f"Признак, используемый для разбиения: {feature_used}")
        print(f"ОТВЕТ: {feature_used}")
        
        return feature_used
    
    def question2_random_forest_rmse(self, n_estimators=10):
        """Вопрос 2: Random Forest с 10 деревьями"""
        print("\n" + "="*60)
        print(f"ВОПРОС 2: RANDOM FOREST (n_estimators={n_estimators})")
        print("="*60)
        
        rf = RandomForestRegressor(
            n_estimators=n_estimators, 
            random_state=1, 
            n_jobs=-1
        )
        rf.fit(self.X_train_encoded, self.y_train)
        
        y_pred = rf.predict(self.X_val_encoded)
        rmse = np.sqrt(mean_squared_error(self.y_val, y_pred))
        
        print(f"RMSE на валидации: {rmse:.5f}")
        print(f"ОТВЕТ: {rmse:.5f}")
        
        return rmse
    
    def question3_optimal_n_estimators(self, max_n=200, step=10):
        """Вопрос 3: Поиск оптимального количества деревьев"""
        print("\n" + "="*60)
        print("ВОПРОС 3: ПОИСК ОПТИМАЛЬНОГО n_estimators")
        print("="*60)
        
        n_estimators_range = range(step, max_n + step, step)
        results = []
        best_rmse = float('inf')
        best_n = 0
        
        for n in n_estimators_range:
            rf = RandomForestRegressor(
                n_estimators=n, 
                random_state=1, 
                n_jobs=-1
            )
            rf.fit(self.X_train_encoded, self.y_train)
            y_pred = rf.predict(self.X_val_encoded)
            rmse = np.sqrt(mean_squared_error(self.y_val, y_pred))
            results.append((n, rmse))
            
            print(f"n_estimators={n}: RMSE={rmse:.3f}")
            
            if rmse < best_rmse:
                best_rmse = rmse
                best_n = n
        
        # Анализ стабилизации
        rmse_values = [r[1] for r in results]
        stabilized = False
        stabilization_point = best_n
        
        for i in range(len(rmse_values) - 3):
            if abs(rmse_values[i] - rmse_values[i+1]) < 0.01 and \
               abs(rmse_values[i+1] - rmse_values[i+2]) < 0.01:
                stabilized = True
                stabilization_point = n_estimators_range[i]
                break
        
        print(f"\nЛучший RMSE: {best_rmse:.3f} при n_estimators={best_n}")
        print(f"RMSE стабилизируется после n_estimators={stabilization_point}")
        print(f"ОТВЕТ: {stabilization_point}")
        
        return stabilization_point, results
    
    def question4_optimal_max_depth(self, max_depths=[10, 15, 20, 25], 
                                    n_estimators_range=range(10, 201, 10)):
        """Вопрос 4: Поиск оптимальной максимальной глубины"""
        print("\n" + "="*60)
        print("ВОПРОС 4: ПОИСК ОПТИМАЛЬНОЙ max_depth")
        print("="*60)
        
        results = {}
        
        for depth in max_depths:
            rmse_scores = []
            
            for n in n_estimators_range:
                rf = RandomForestRegressor(
                    n_estimators=n,
                    max_depth=depth,
                    random_state=1,
                    n_jobs=-1
                )
                rf.fit(self.X_train_encoded, self.y_train)
                y_pred = rf.predict(self.X_val_encoded)
                rmse = np.sqrt(mean_squared_error(self.y_val, y_pred))
                rmse_scores.append(rmse)
            
            avg_rmse = np.mean(rmse_scores)
            results[depth] = {
                'avg_rmse': avg_rmse,
                'min_rmse': min(rmse_scores),
                'std_rmse': np.std(rmse_scores)
            }
            
            print(f"max_depth={depth}:")
            print(f"  Средний RMSE: {avg_rmse:.3f}")
            print(f"  Мин. RMSE: {min(rmse_scores):.3f}")
            print(f"  Станд. откл.: {np.std(rmse_scores):.3f}")
        
        best_depth = min(results, key=lambda x: results[x]['avg_rmse'])
        print(f"\nЛучшая max_depth: {best_depth}")
        print(f"ОТВЕТ: {best_depth}")
        
        return best_depth, results
    
    def question5_feature_importance(self, n_estimators=10, max_depth=20):
        """Вопрос 5: Анализ важности признаков"""
        print("\n" + "="*60)
        print("ВОПРОС 5: ВАЖНОСТЬ ПРИЗНАКОВ")
        print("="*60)
        
        rf_final = RandomForestRegressor(
            n_estimators=n_estimators,
            max_depth=max_depth,
            random_state=1,
            n_jobs=-1
        )
        rf_final.fit(self.X_train_encoded, self.y_train)
        
        # Словарь важности признаков
        feature_importance_dict = dict(zip(
            self.feature_names, 
            rf_final.feature_importances_
        ))
        
        # Интересующие признаки
        target_features = [
            'study_hours_per_week',
            'attendance_rate', 
            'distance_to_school',
            'teacher_quality'
        ]
        
        most_important = None
        highest_importance = 0
        importance_results = {}
        
        print("Важность признаков:")
        for feature in target_features:
            if feature in feature_importance_dict:
                importance = feature_importance_dict[feature]
                importance_results[feature] = importance
                print(f"{feature}: {importance:.4f}")
                
                if importance > highest_importance:
                    highest_importance = importance
                    most_important = feature
        
        print(f"\nСамый важный признак: {most_important}")
        print(f"ОТВЕТ: {most_important}")
        
        # Сортировка всех признаков по важности
        all_features_sorted = sorted(
            feature_importance_dict.items(), 
            key=lambda x: x[1], 
            reverse=True
        )
        
        print("\nТоп-10 всех признаков по важности:")
        for i, (feat, imp) in enumerate(all_features_sorted[:10], 1):
            print(f"{i:2d}. {feat[:30]}: {imp:.4f}")
        
        return most_important, importance_results
    
    def train_final_model(self, n_estimators=90, max_depth=10):
        """Обучение финальной модели на всех обучающих данных"""
        print("\n" + "="*60)
        print("ОБУЧЕНИЕ ФИНАЛЬНОЙ МОДЕЛИ")
        print("="*60)
        
        # Объединяем train и val для финального обучения
        X_full_train = np.vstack([self.X_train_encoded.toarray(), 
                                   self.X_val_encoded.toarray()])
        y_full_train = np.concatenate([self.y_train, self.y_val])
        
        rf_final = RandomForestRegressor(
            n_estimators=n_estimators,
            max_depth=max_depth,
            random_state=1,
            n_jobs=-1
        )
        rf_final.fit(X_full_train, y_full_train)
        
        # Оценка на тесте
        y_test_pred = rf_final.predict(self.X_test_encoded)
        test_rmse = np.sqrt(mean_squared_error(self.y_test, y_test_pred))
        
        print(f"Финальная модель:")
        print(f"  n_estimators={n_estimators}")
        print(f"  max_depth={max_depth}")
        print(f"  Тестовый RMSE: {test_rmse:.3f}")
        
        return rf_final, test_rmse
    
    def run_complete_analysis(self):
        """Запуск полного анализа"""
        print("\n" + "="*60)
        print("КОМПЛЕКСНЫЙ АНАЛИЗ ДАННЫХ JAMB")
        print("="*60)
        
        # Загрузка и предобработка
        self.load_and_preprocess()
        self.explore_data()
        
        # Разделение и кодирование
        self.split_data()
        self.encode_features()
        
        # Ответы на вопросы
        print("\n" + "="*60)
        print("РЕЗУЛЬТАТЫ ПО ВОПРОСАМ")
        print("="*60)
        
        q1 = self.question1_decision_tree_depth1()
        q2 = self.question2_random_forest_rmse(10)
        q3_n, q3_results = self.question3_optimal_n_estimators()
        q4_depth, q4_results = self.question4_optimal_max_depth()
        q5_feat, q5_results = self.question5_feature_importance(10, 20)
        
        # Обучение финальной модели
        final_model, test_rmse = self.train_final_model(
            n_estimators=q3_n, 
            max_depth=q4_depth
        )
        
        # Сводка результатов
        print("\n" + "="*60)
        print("СВОДКА РЕЗУЛЬТАТОВ")
        print("="*60)
        
        results_summary = pd.DataFrame({
            'Вопрос': [
                '1. Признак в дереве (depth=1)',
                '2. RMSE (n=10)',
                '3. Оптимальное n_estimators',
                '4. Оптимальная max_depth',
                '5. Самый важный признак',
                'Финальный тестовый RMSE'
            ],
            'Ответ': [
                q1,
                f"{q2:.5f}",
                q3_n,
                q4_depth,
                q5_feat,
                f"{test_rmse:.3f}"
            ]
        })
        
        print(results_summary.to_string(index=False))
        
        return results_summary


def main():
    """Основная функция выполнения"""
    predictor = JAMBScorePredictor('jamb_exam_results.csv')
    results = predictor.run_complete_analysis()
    
    print("\n" + "="*60)
    print("АНАЛИЗ ЗАВЕРШЕН УСПЕШНО")
    print("="*60)
    
    return predictor, results


if __name__ == "__main__":
    predictor, results = main()
