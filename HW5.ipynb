# -*- coding: utf-8 -*-
"""JAMB Exam Score Prediction - Рабочая версия"""

import pandas as pd
import numpy as np
from sklearn.model_selection import train_test_split
from sklearn.feature_extraction import DictVectorizer
from sklearn.tree import DecisionTreeRegressor
from sklearn.ensemble import RandomForestRegressor
from sklearn.metrics import mean_squared_error
import warnings
warnings.filterwarnings('ignore')

# ==================== ЗАГРУЗКА И ПРЕДОБРАБОТКА ====================

# Загрузка данных
df = pd.read_csv('jamb_exam_results.csv')
print("="*60)
print("ЗАГРУЗКА ДАННЫХ")
print("="*60)
print(f"Размер данных: {df.shape}")

# Очистка названий колонок
df.columns = df.columns.str.lower().str.replace(' ', '_')

# Удаление student_id
if 'student_id' in df.columns:
    df = df.drop('student_id', axis=1)
    print("✓ Удален столбец student_id")

# Заполнение пропусков
df = df.fillna(0)
print("✓ Пропуски заполнены нулями")

print("\nПервые 5 строк:")
print(df.head())

# ==================== РАЗДЕЛЕНИЕ ДАННЫХ ====================

print("\n" + "="*60)
print("РАЗДЕЛЕНИЕ ДАННЫХ")
print("="*60)

# Признаки и целевая переменная
X = df.drop('jamb_score', axis=1)
y = df['jamb_score']

# Разделение на train/validation/test
X_train_full, X_test, y_train_full, y_test = train_test_split(
    X, y, test_size=0.2, random_state=1
)

X_train, X_val, y_train, y_val = train_test_split(
    X_train_full, y_train_full, test_size=0.25, random_state=1
)

print(f"Обучающая выборка: {len(X_train)} образцов")
print(f"Валидационная выборка: {len(X_val)} образцов")
print(f"Тестовая выборка: {len(X_test)} образцов")

# ==================== КОДИРОВАНИЕ ПРИЗНАКОВ ====================

print("\n" + "="*60)
print("КОДИРОВАНИЕ ПРИЗНАКОВ")
print("="*60)

# Преобразование в словари
train_dict = X_train.to_dict(orient='records')
val_dict = X_val.to_dict(orient='records')
test_dict = X_test.to_dict(orient='records')

# Кодирование
dv = DictVectorizer(sparse=True)
X_train_encoded = dv.fit_transform(train_dict)
X_val_encoded = dv.transform(val_dict)
X_test_encoded = dv.transform(test_dict)

feature_names = dv.get_feature_names_out()
print(f"✓ Признаки закодированы")
print(f"Количество признаков: {len(feature_names)}")

# ==================== ВОПРОС 1 ====================

print("\n" + "="*60)
print("ВОПРОС 1: ДЕРЕВО РЕШЕНИЙ (max_depth=1)")
print("="*60)

dt = DecisionTreeRegressor(max_depth=1, random_state=1)
dt.fit(X_train_encoded, y_train)

feature_used = feature_names[dt.tree_.feature[0]]
print(f"Признак для разбиения: {feature_used}")
answer1 = feature_used

# ==================== ВОПРОС 2 ====================

print("\n" + "="*60)
print("ВОПРОС 2: RANDOM FOREST (n_estimators=10)")
print("="*60)

rf = RandomForestRegressor(n_estimators=10, random_state=1, n_jobs=-1)
rf.fit(X_train_encoded, y_train)
y_pred = rf.predict(X_val_encoded)
rmse = np.sqrt(mean_squared_error(y_val, y_pred))
print(f"RMSE = {rmse:.5f}")
answer2 = rmse

# ==================== ВОПРОС 3 ====================

print("\n" + "="*60)
print("ВОПРОС 3: ПОИСК ОПТИМАЛЬНОГО n_estimators")
print("="*60)

n_estimators_values = range(10, 201, 10)
results_q3 = []
best_rmse = float('inf')
best_n = 0

for n in n_estimators_values:
    rf = RandomForestRegressor(n_estimators=n, random_state=1, n_jobs=-1)
    rf.fit(X_train_encoded, y_train)
    y_pred = rf.predict(X_val_encoded)
    rmse = np.sqrt(mean_squared_error(y_val, y_pred))
    results_q3.append((n, rmse))
    
    print(f"n_estimators={n}: RMSE={rmse:.3f}")
    
    if rmse < best_rmse:
        best_rmse = rmse
        best_n = n

print(f"\nЛучший RMSE: {best_rmse:.3f} при n_estimators={best_n}")

# Определяем момент стабилизации
rmse_values = [r[1] for r in results_q3]
stabilization_point = best_n
for i in range(len(rmse_values) - 2):
    if abs(rmse_values[i] - rmse_values[i+1]) < 0.05 and \
       abs(rmse_values[i+1] - rmse_values[i+2]) < 0.05:
        stabilization_point = n_estimators_values[i]
        break

print(f"RMSE стабилизируется после n_estimators={stabilization_point}")
answer3 = stabilization_point

# ==================== ВОПРОС 4 ====================

print("\n" + "="*60)
print("ВОПРОС 4: ПОИСК ОПТИМАЛЬНОЙ max_depth")
print("="*60)

max_depth_values = [10, 15, 20, 25]
results_q4 = {}

for depth in max_depth_values:
    rmse_scores = []
    
    for n in n_estimators_values:
        rf = RandomForestRegressor(
            n_estimators=n,
            max_depth=depth,
            random_state=1,
            n_jobs=-1
        )
        rf.fit(X_train_encoded, y_train)
        y_pred = rf.predict(X_val_encoded)
        rmse = np.sqrt(mean_squared_error(y_val, y_pred))
        rmse_scores.append(rmse)
    
    avg_rmse = np.mean(rmse_scores)
    results_q4[depth] = {
        'avg_rmse': avg_rmse,
        'min_rmse': min(rmse_scores),
        'std_rmse': np.std(rmse_scores)
    }
    
    print(f"max_depth={depth}:")
    print(f"  Средний RMSE: {avg_rmse:.3f}")
    print(f"  Мин. RMSE: {min(rmse_scores):.3f}")

best_depth = min(results_q4, key=lambda x: results_q4[x]['avg_rmse'])
print(f"\nЛучшая max_depth: {best_depth}")
answer4 = best_depth

# ==================== ВОПРОС 5 ====================

print("\n" + "="*60)
print("ВОПРОС 5: АНАЛИЗ ВАЖНОСТИ ПРИЗНАКОВ")
print("="*60)

rf_final = RandomForestRegressor(
    n_estimators=10,
    max_depth=20,
    random_state=1,
    n_jobs=-1
)
rf_final.fit(X_train_encoded, y_train)

feature_importances = rf_final.feature_importances_
feature_importance_dict = dict(zip(feature_names, feature_importances))

target_features = [
    'study_hours_per_week',
    'attendance_rate', 
    'distance_to_school',
    'teacher_quality'
]

results_q5 = {}
most_important = None
highest_importance = 0

for feature in target_features:
    # Ищем признак в словаре (может быть с префиксом)
    found = False
    for feat_name in feature_importance_dict.keys():
        if feature in feat_name:
            importance = feature_importance_dict[feat_name]
            results_q5[feature] = importance
            print(f"{feature}: {importance:.4f}")
            
            if importance > highest_importance:
                highest_importance = importance
                most_important = feature
            found = True
            break
    
    if not found:
        print(f"{feature}: не найден")
        results_q5[feature] = 0

print(f"\nСамый важный признак: {most_important}")
answer5 = most_important

# ==================== ФИНАЛЬНАЯ МОДЕЛЬ ====================

print("\n" + "="*60)
print("ФИНАЛЬНАЯ МОДЕЛЬ")
print("="*60)

# Объединяем train и val для финального обучения
from scipy.sparse import vstack
X_full_train = vstack([X_train_encoded, X_val_encoded])
y_full_train = np.concatenate([y_train, y_val])

rf_best = RandomForestRegressor(
    n_estimators=answer3,
    max_depth=answer4,
    random_state=1,
    n_jobs=-1
)
rf_best.fit(X_full_train, y_full_train)

# Оценка на тесте
y_test_pred = rf_best.predict(X_test_encoded)
test_rmse = np.sqrt(mean_squared_error(y_test, y_test_pred))

print(f"Финальная модель:")
print(f"  n_estimators={answer3}")
print(f"  max_depth={answer4}")
print(f"  Тестовый RMSE: {test_rmse:.3f}")

# ==================== СВОДКА РЕЗУЛЬТАТОВ ====================

print("\n" + "="*60)
print("ИТОГОВЫЕ ОТВЕТЫ")
print("="*60)

results = pd.DataFrame({
    'Вопрос': [
        '1. Признак в дереве (depth=1)',
        '2. RMSE (n_estimators=10)',
        '3. Оптимальное n_estimators',
        '4. Оптимальная max_depth',
        '5. Самый важный признак'
    ],
    'Ответ': [
        answer1,
        f"{answer2:.5f}",
        answer3,
        answer4,
        answer5
    ]
})

print(results.to_string(index=False))

# Сохраняем результаты в файл
results.to_csv('jamb_results.csv', index=False)
print("\n✓ Результаты сохранены в 'jamb_results.csv'")

# Дополнительно: сохраняем модель
import joblib
model_artifacts = {
    'model': rf_best,
    'dict_vectorizer': dv,
    'feature_names': feature_names,
    'results': results
}
joblib.dump(model_artifacts, 'jamb_model.pkl')
print("✓ Модель сохранена в 'jamb_model.pkl'")

print("\n" + "="*60)
print("ВЫПОЛНЕНИЕ ЗАВЕРШЕНО")
print("="*60)
